---
import SiteLayout from "@layouts/SiteLayout.astro";
import ContactForm from "@components/ContactForm";
---

<SiteLayout
  title="Contact | Rob Cipolla"
  description="Get in touch — whether you have a project in mind or just want to say hello."
  ogImage="/og/contact.png"
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-nightfall">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-ember/[0.03]"></div>

    <div class="mx-auto max-w-5xl px-6 pb-20 pt-36 lg:px-8 lg:pb-24 lg:pt-44">

      <p class="mb-6 font-mono text-[11px] uppercase tracking-[0.14em] text-chalk/50">RC · Contact</p>

      <h1 class="font-serif text-4xl leading-[1.05] text-chalk sm:text-5xl">Get in touch</h1>

      <div class="mt-6 h-0.5 w-8 bg-ember"></div>

      <p class="mt-6 max-w-lg text-[15px] font-light leading-relaxed text-chalk/50">
        I'm always open to new opportunities and collaborations. If you have a project in mind, or just want to say hello.
      </p>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════ -->
  <!-- CONTACT FORM                                    -->
  <!-- ════════════════════════════════════════════════ -->
  <section>
    <div class="mx-auto max-w-5xl px-6 py-20 lg:px-8 lg:py-28">

      <!-- Section label -->
      <div class="mb-12 flex items-center gap-3">
        <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-dusk">01 — Say hello</span>
        <span class="h-px flex-1 bg-rule"></span>
      </div>

      <div class="max-w-xl">
        <p class="mb-8 text-[15px] leading-relaxed text-dusk">
          You can reach me directly at
          <a
            href="mailto:hello@robcipolla.co.uk"
            class="text-ember transition-colors hover:text-ember/70"
          >
            hello@robcipolla.co.uk
          </a>
          , or use the form below.
        </p>

        <ContactForm
          client:visible
          formId={import.meta.env.FORMSPREE_FORM_ID}
        />
      </div>
    </div>
  </section>
</SiteLayout>

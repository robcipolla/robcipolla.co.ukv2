---
import Calendar from "@components/icons/Calendar.astro";
import WhatPeopleSay from "@components/sections/WhatPeopleSay.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { getCollection } from "astro:content";
import { compareDesc, format } from "date-fns";

const yearsExperience = new Date().getFullYear() - 2016;

const posts = await getCollection("blog");
const orderedPosts = posts.sort((a, b) =>
  compareDesc(new Date(a.data.date), new Date(b.data.date))
);
---

<SiteLayout
  title="Rob Cipolla | Product Engineer"
  description="Product engineer and designer. I build user-facing software with a focus on craft, performance, and product thinking."
  ogImage="/og/home.png"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Rob Cipolla",
    "url": "https://www.robcipolla.co.uk",
    "author": {
      "@type": "Person",
      "name": "Rob Cipolla",
      "jobTitle": "Product Engineer",
      "url": "https://www.robcipolla.co.uk",
      "sameAs": [
        "https://www.linkedin.com/in/rob-cipolla",
        "https://github.com/robcipolla",
        "https://twitter.com/robcipolla"
      ]
    }
  })} />
  <!-- ════════════════════════════════════════════════ -->
  <!-- HERO                                            -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-nightfall">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-ember/[0.03]"></div>

    <div class="mx-auto max-w-5xl px-6 pb-14 pt-36 lg:px-8 lg:pb-16 lg:pt-44">

      <!-- Eyebrow -->
      <p class="mb-6 font-mono text-xs uppercase tracking-[0.14em] text-chalk/60">Rob Cipolla · Lexicon</p>

      <!-- Headline — the dictionary device -->
      <h1 class="font-serif text-4xl leading-[1.05] text-chalk sm:text-5xl lg:text-6xl">
        Product Engineer,<br /><em class="text-chalk/80">noun</em>
      </h1>

      <!-- Phonetics -->
      <p class="mt-3 font-mono text-sm tracking-wide text-ember-a11y">/ ˈprɒd.əkt ˌen.dʒɪˈnɪər /</p>

      <!-- Ember rule -->
      <div class="mt-8 h-0.5 w-8 bg-ember"></div>

      <!-- Definition -->
      <div class="mt-6 border-l-2 border-ember/50 pl-5">
        <p class="max-w-lg text-base leading-relaxed text-chalk/65">
          A software engineer who combines product intuition with full-stack capability, designing, building, and iterating on user-facing features without losing sight of why they exist.
        </p>
      </div>

      <!-- Origin -->
      <p class="mt-6 font-mono text-xs text-chalk/60">
        Rob Cipolla. Leicester, UK. 10+ years building for the web. Currently at <a class="text-ember-a11y transition-colors hover:text-ember-light" href="https://locale.co.uk">Locale</a>.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3 pt-10">
        <a
          class="rounded bg-chalk px-5 py-2.5 text-sm font-medium text-ink transition-colors hover:bg-ember hover:text-chalk"
          href="/about"
        >
          About me
        </a>
        <a
          class="rounded border border-chalk/15 px-5 py-2.5 text-sm font-medium text-chalk/65 transition-all hover:border-chalk/40 hover:text-chalk"
          href="/blog"
        >
          Read the blog
        </a>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════ -->
  <!-- RECENT POSTS                                    -->
  <!-- ════════════════════════════════════════════════ -->
  <section>
    <div class="mx-auto max-w-5xl px-6 py-16 lg:px-8 lg:py-20">

      <!-- Section label -->
      <div class="mb-12 flex items-center gap-3">
        <span class="font-mono text-xs uppercase tracking-[0.12em] text-dusk">01. Recent posts</span>
        <span class="h-px flex-1 bg-rule"></span>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          orderedPosts.slice(0, 3).map((post, i) => (
            <article class="group relative flex flex-col justify-between rounded-lg border border-rule bg-chalk p-7 transition-all duration-300 hover:border-dusk/40">

              <!-- Ghost numeral -->
              <span class="pointer-events-none absolute right-5 top-4 select-none font-serif text-7xl leading-none text-rule/40">
                {String(i + 1).padStart(2, "0")}
              </span>

              <div class="relative space-y-4">
                <!-- Mono tag -->
                <span class="inline-block rounded border border-rule px-2 py-0.5 font-mono text-xs uppercase tracking-wider text-dusk">
                  article
                </span>

                <h2 class="font-serif text-lg leading-snug text-ink">{post.data.title}</h2>

                <div class="flex items-center gap-2 font-mono text-xs text-dusk">
                  <Calendar class="h-3.5 w-3.5" />
                  <span>{format(post.data.date, "MMM yyyy")}</span>
                </div>
              </div>

              <div class="pt-7">
                <a
                  class="inline-flex items-center gap-1.5 text-sm font-medium text-ink transition-colors group-hover:text-ember"
                  href={`/blog/${post.slug}`}
                >
                  Read post
                  <span class="transition-transform duration-200 group-hover:translate-x-0.5">&rarr;</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-10 text-center">
        <a
          class="inline-block rounded border border-rule px-5 py-2.5 text-sm font-medium text-dusk transition-all hover:border-ink hover:text-ink"
          href="/blog"
        >
          View all posts
        </a>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════ -->
  <!-- SERVICES                                        -->
  <!-- ════════════════════════════════════════════════ -->
  <section class="bg-nightfall">
    <div class="mx-auto max-w-5xl px-6 py-16 lg:px-8 lg:py-20">

      <!-- Section label -->
      <div class="mb-12 flex items-center gap-3">
        <span class="font-mono text-xs uppercase tracking-[0.12em] text-chalk/60">02. Services</span>
        <span class="h-px flex-1 bg-chalk/[0.06]"></span>
      </div>

      <div class="max-w-2xl">
        <!-- Pull quote -->
        <div class="mb-6 border-l-2 border-ember/60 pl-5">
          <p class="font-serif text-xl leading-snug text-chalk sm:text-2xl">
            I take on select freelance projects: websites, apps, and digital products where design and engineering need to work together.
          </p>
        </div>

        <p class="text-base leading-relaxed text-chalk/60">
          If you have something you'd like to bring to life, I'd love to hear about it.
        </p>

        <div class="pt-8">
          <a
            class="inline-flex items-center gap-2 rounded border border-chalk/15 px-5 py-2.5 text-sm font-medium text-chalk/75 transition-all hover:border-ember hover:text-ember-a11y"
            href="/contact"
          >
            Get in touch
            <span>&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════ -->
  <!-- ABOUT                                           -->
  <!-- ════════════════════════════════════════════════ -->
  <section>
    <div class="mx-auto max-w-5xl px-6 py-16 lg:px-8 lg:py-20">

      <!-- Section label -->
      <div class="mb-12 flex items-center gap-3">
        <span class="font-mono text-xs uppercase tracking-[0.12em] text-dusk">03. About</span>
        <span class="h-px flex-1 bg-rule"></span>
      </div>

      <div class="max-w-2xl">
        <!-- Pull quote -->
        <div class="mb-6 border-l-2 border-ember pl-5">
          <p class="font-serif text-xl leading-snug text-ink sm:text-2xl">
            Product engineer and designer with over {yearsExperience} years of experience shipping software that works as well as it looks.
          </p>
        </div>

        <p class="text-base leading-relaxed text-dusk">
          I work across the full stack: React, Next.js, TypeScript on the front, Node on the back. The bit I care about most is where design and engineering meet: building interfaces that feel considered, backed by systems that hold up.
        </p>

        <div class="pt-8">
          <a
            class="inline-flex items-center gap-2 rounded bg-ink px-5 py-2.5 text-sm font-medium text-chalk transition-colors hover:bg-ember"
            href="/about"
          >
            More about me
            <span>&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════════ -->
  <!-- RECOMMENDATIONS                                 -->
  <!-- ════════════════════════════════════════════════ -->
  <WhatPeopleSay />
</SiteLayout>

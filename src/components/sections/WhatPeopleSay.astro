---
import LinkedIn from "@components/icons/LinkedIn.astro";
import recommendations from "@utils/constants/recommendations.json";

const recommends = recommendations.recommendations;
---

<section>
  <div class="mx-auto max-w-5xl px-6 py-20 lg:px-8 lg:py-28">

    <!-- Section label -->
    <div class="mb-12 flex items-center gap-3">
      <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-dusk">03 — Recommendations</span>
      <span class="h-px flex-1 bg-rule"></span>
    </div>

    <div class="space-y-5">
      {
        recommends.map((recommend) => (
          <article class="rounded-lg border border-rule bg-chalk p-6 transition-colors duration-300 hover:border-dusk/40 lg:p-8">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-serif text-lg text-ink">
                  {recommend.name}
                </h3>
                <p class="font-mono text-[11px] tracking-wide text-dusk">{recommend.role}</p>
              </div>
              <a
                href={recommend.link}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1 shrink-0 text-[#0077B5] transition-opacity hover:opacity-60"
              >
                <span class="sr-only">View {recommend.name}'s LinkedIn</span>
                <LinkedIn class="h-5 w-5" />
              </a>
            </div>
            <div class="mt-4 max-w-2xl text-[14px] leading-relaxed text-dusk [&>p+p]:mt-3" set:html={recommend.text} />
          </article>
        ))
      }
    </div>
  </div>
</section>

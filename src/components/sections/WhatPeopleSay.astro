---
import LinkedIn from "@components/icons/LinkedIn.astro";
import recommendations from "@utils/constants/recommendations.json";

const recommends = recommendations.recommendations;
---

<section>
  <div class="mx-auto max-w-5xl px-6 py-16 lg:px-8 lg:py-20">

    <!-- Section label -->
    <div class="mb-12 flex items-center gap-3">
      <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-dusk">04 — Recommendations</span>
      <span class="h-px flex-1 bg-rule"></span>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        recommends.map((recommend) => (
          <article class="flex flex-col justify-between rounded-lg border border-rule bg-chalk p-6 transition-colors duration-300 hover:border-dusk/40 lg:p-7">
            <div>
              <div class="flex items-start justify-between gap-3">
                <div>
                  <h2 class="text-[15px] font-semibold text-ink">{recommend.name}</h2>
                  <p class="mt-0.5 font-mono text-[10px] tracking-wide text-dusk">{recommend.role}</p>
                </div>
                <a
                  href={recommend.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-0.5 shrink-0 text-[#0077B5] transition-opacity hover:opacity-60"
                >
                  <span class="sr-only">View {recommend.name}'s LinkedIn</span>
                  <LinkedIn class="h-4 w-4" />
                </a>
              </div>

              <p class="mt-4 text-[14px] leading-relaxed text-dusk">
                "{recommend.text}"
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

---
import Logo from "@components/Logo.astro";
import LinkedIn from "@components/icons/LinkedIn.astro";
import X from "@components/icons/X.astro";
import Envelope from "@components/icons/Envelope.astro";
import Menu from "@components/icons/Menu.astro";
import CloseMenu from "@components/icons/CloseMenu.astro";
import Github from "./icons/Github.astro";

const navLinks = [
  { name: "Home", href: "/" },
  { name: "About", href: "/about" },
  { name: "Blog", href: "/blog" },
];
---

<header
  class="fixed top-0 z-50 w-full transition-all duration-500"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-5 lg:px-8">
    <!-- Logo -->
    <a id="header-logo" class="relative z-10 transition-opacity duration-300 hover:opacity-60" href="/">
      <span class="sr-only">Home Link</span>
      <Logo variant="light" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-10 lg:flex">
      <ul class="flex items-center gap-8">
        {
          navLinks.map((link) => (
            <li>
              <a
                class="text-[13px] font-medium tracking-wide text-chalk/80 transition-colors duration-300 hover:text-chalk"
                href={link.href}
              >
                {link.name}
              </a>
            </li>
          ))
        }
      </ul>

      <span class="h-4 w-px bg-chalk/15"></span>

      <div class="flex items-center gap-3">
        <a
          class="text-chalk/60 transition-colors duration-300 hover:text-chalk/80"
          href="https://www.linkedin.com/in/rob-cipolla"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="sr-only">LinkedIn</span>
          <LinkedIn class="h-4 w-4" />
        </a>
        <a
          class="text-chalk/60 transition-colors duration-300 hover:text-chalk/80"
          href="https://twitter.com/robcipolla"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="sr-only">Twitter/X</span>
          <X class="h-4 w-4" />
        </a>
        <a
          class="text-chalk/60 transition-colors duration-300 hover:text-chalk/80"
          href="https://github.com/robcipolla"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="sr-only">GitHub</span>
          <Github class="h-4 w-4" />
        </a>
      </div>

      <a
        id="contact-button"
        class="rounded border border-chalk/20 px-4 py-2 text-[13px] font-medium text-chalk/80 transition-all duration-300 hover:border-chalk/50 hover:text-chalk"
        href="/contact"
      >
        Get in touch
      </a>
    </nav>

    <!-- Mobile controls -->
    <div id="right-side" class="flex items-center gap-3 lg:hidden">
      <a
        aria-label="Get in touch"
        id="mobile-contact"
        class="rounded border border-chalk/20 p-2 text-chalk/70 transition-colors hover:text-chalk"
        href="/contact"
      >
        <Envelope className="h-5 w-5" />
      </a>
      <button
        class="rounded border border-chalk/20 p-2 text-chalk/70 transition-colors hover:text-chalk"
        aria-label="Open menu"
      >
        <Menu id="open-menu-icon" class="h-5 w-5" />
        <CloseMenu id="close-menu-icon" class="hidden h-5 w-5" />
      </button>
    </div>
  </div>
</header>

<!-- Mobile menu -->
<nav
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 z-40 flex flex-col items-center justify-center bg-nightfall/95 opacity-0 backdrop-blur-md transition-all duration-300 lg:!hidden"
>
  <ul class="flex flex-col items-center gap-6">
    {
      navLinks.map((link) => (
        <li>
          <a class="font-serif text-3xl text-chalk/80 transition-colors hover:text-chalk" href={link.href}>
            {link.name}
          </a>
        </li>
      ))
    }
    <li class="pt-4">
      <a
        class="rounded border border-chalk/20 px-6 py-3 text-sm font-medium text-chalk/80 transition-colors hover:border-chalk/50 hover:text-chalk"
        href="/contact"
      >
        Get in touch
      </a>
    </li>
  </ul>
  <div class="flex items-center gap-4 pt-10">
    <a
      class="text-chalk/60 transition-colors hover:text-chalk/80"
      href="https://www.linkedin.com/in/rob-cipolla"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="sr-only">LinkedIn</span>
      <LinkedIn class="h-5 w-5" />
    </a>
    <a
      class="text-chalk/60 transition-colors hover:text-chalk/80"
      href="https://twitter.com/robcipolla"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="sr-only">Twitter/X</span>
      <X class="h-5 w-5" />
    </a>
    <a
      class="text-chalk/60 transition-colors hover:text-chalk/80"
      href="https://github.com/robcipolla"
      target="_blank"
      rel="noopener noreferrer"
    >
      <span class="sr-only">GitHub</span>
      <Github class="h-5 w-5" />
    </a>
  </div>
</nav>

<style>
  .header-scrolled {
    background-color: rgba(244, 241, 236, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(214, 210, 203, 0.5);
  }

  .header-scrolled a {
    color: #1A1814;
  }

  .header-scrolled nav a {
    color: #57534E;
  }

  .header-scrolled nav a:hover {
    color: #1A1814;
  }

  .header-scrolled :global(svg path) {
    fill: #1A1814;
  }

  .header-scrolled nav :global(svg path) {
    fill: #57534E;
  }

  .header-scrolled nav a:hover :global(svg path) {
    fill: #1A1814;
  }

  .header-scrolled nav span {
    background-color: rgba(214, 210, 203, 0.5);
  }

  .header-scrolled #contact-button {
    color: #FDFCFA;
    background-color: #1A1814;
    border-color: #1A1814;
  }

  .header-scrolled #contact-button:hover {
    background-color: #C1440E;
    border-color: #C1440E;
  }

  .header-scrolled #contact-button :global(svg path) {
    fill: #FDFCFA;
  }

  #right-side :global(svg path) {
    fill: currentColor;
  }

  .header-scrolled #right-side a,
  .header-scrolled #right-side button {
    color: #57534E;
    border-color: rgba(214, 210, 203, 1);
  }

  .header-scrolled #right-side :global(svg path) {
    fill: #57534E;
  }

  .header-scrolled #right-side a:hover,
  .header-scrolled #right-side button:hover {
    color: #1A1814;
  }

  .header-scrolled #right-side a:hover :global(svg path),
  .header-scrolled #right-side button:hover :global(svg path) {
    fill: #1A1814;
  }

  .mobile-menu-open #header-logo :global(svg path) {
    fill: #FDFCFA;
  }

  .mobile-menu-open #right-side a,
  .mobile-menu-open #right-side button {
    color: rgba(253, 252, 250, 0.7);
    border-color: rgba(253, 252, 250, 0.2);
  }

  .mobile-menu-open #right-side :global(svg path) {
    fill: rgba(253, 252, 250, 0.7);
  }

  .mobile-menu-open.header-scrolled {
    background-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    border-bottom: none;
  }
</style>

<script is:inline>
  const header = document.querySelector("header");
  let menuOpen = false;

  function headerScroll() {
    if (header && !menuOpen) {
      header.classList.toggle("header-scrolled", window.scrollY > 0);
    }
  }

  function toggleMenu() {
    const openMenuIcon = document.getElementById("open-menu-icon");
    const closeMenuIcon = document.getElementById("close-menu-icon");
    const body = document.getElementsByTagName("body")[0];
    const menu = document.getElementById("mobile-menu");

    if (header) {
      header.classList.toggle("mobile-menu-open");
    }

    openMenuIcon?.classList.toggle("hidden");
    closeMenuIcon?.classList.toggle("hidden");
    body?.classList?.toggle("overflow-hidden");

    if (menu) {
      menu.style.opacity = menuOpen ? "0" : "1";
      menu.style.pointerEvents = menuOpen ? "none" : "all";
    }

    menuOpen = !menuOpen;

    // Re-evaluate scroll state after closing
    if (!menuOpen) {
      headerScroll();
    }
  }
</script>

<script is:inline>
  document.querySelector("button")?.addEventListener("click", toggleMenu);

  window.addEventListener("scroll", headerScroll);
  window.addEventListener("load", headerScroll);
</script>

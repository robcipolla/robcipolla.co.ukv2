---
import Calendar from "@components/icons/Calendar.astro";
import Clock from "@components/icons/Clock.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { format } from "date-fns";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    excerpt: string;
    readingTime: number;
  };
  slug: string;
}

const { frontmatter, slug } = Astro.props;
const postedAt = format(frontmatter.date, "MMM dd, yyyy");
---

<SiteLayout
  title={`${frontmatter.title} | Rob Cipolla`}
  description={frontmatter.description}
  ogImage={`/blog/${slug}/og.png`}
  type="article"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": frontmatter.title,
    "description": frontmatter.description,
    "datePublished": frontmatter.date.toISOString(),
    "author": {
      "@type": "Person",
      "name": "Rob Cipolla",
      "url": "https://www.robcipolla.co.uk"
    },
    "image": `https://www.robcipolla.co.uk/blog/${slug}/og.png`
  })} />
  <!-- Hero -->
  <section class="relative overflow-hidden bg-nightfall">
    <div class="pointer-events-none absolute -right-40 -top-40 h-[600px] w-[600px] rounded-full bg-ember/[0.03]"></div>

    <div class="mx-auto max-w-5xl px-6 pb-20 pt-36 lg:px-8 lg:pb-24 lg:pt-44">

      <!-- Meta eyebrow -->
      <div class="mb-6 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs uppercase tracking-[0.12em] text-chalk/60">
        <span class="text-ember-a11y">article</span>
        <span class="text-chalk/15">·</span>
        <span>{postedAt}</span>
        <span class="text-chalk/15">·</span>
        <span>{frontmatter.readingTime} min read</span>
      </div>

      <!-- Title -->
      <h1 class="max-w-3xl font-serif text-3xl leading-[1.1] text-chalk sm:text-4xl lg:text-5xl">
        {frontmatter.title}
      </h1>

      <!-- Ember rule -->
      <div class="mt-8 h-0.5 w-8 bg-ember"></div>

      <!-- Excerpt -->
      <p class="mt-6 max-w-xl text-base leading-relaxed text-chalk/60">
        {frontmatter.excerpt}
      </p>
    </div>
  </section>

  <!-- Article body -->
  <article>
    <div class="mx-auto max-w-3xl px-6 py-12 lg:px-8 lg:py-16">
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>

      <div class="mt-16 border-t border-rule pt-8">
        <a
          href="/blog"
          class="inline-flex items-center gap-2 rounded border border-rule px-5 py-2.5 text-sm font-medium text-dusk no-underline transition-all hover:border-ink hover:text-ink"
        >
          &larr; Back to blog archive
        </a>
      </div>
    </div>
  </article>
</SiteLayout>

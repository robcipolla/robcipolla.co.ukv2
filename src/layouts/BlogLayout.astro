---
import Calendar from "@components/icons/Calendar.astro";
import Clock from "@components/icons/Clock.astro";
import SiteLayout from "@layouts/SiteLayout.astro";
import { format } from "date-fns";

interface Props {
  frontmatter: {
    title: string;
    description: string;
    date: Date;
    excerpt: string;
    readingTime: number;
  };
  slug: string;
}

const { frontmatter, slug } = Astro.props;
const postedAt = format(frontmatter.date, "MMMM dd, yyyy");
---

<SiteLayout
  title={`${frontmatter.title} | Rob Cipolla`}
  description={frontmatter.description}
  ogImage={`/blog/${slug}/og.png`}
  type="article"
>
  <section class="bg-nightfall">
    <div
      class="container flex flex-col py-28 text-chalk lg:space-y-0 lg:pb-20 lg:pt-40"
    >
      <h1 class="mb-6 text-2xl font-semibold sm:text-5xl">
        {frontmatter.title}
      </h1>
      <div class="flex space-x-4 font-mono text-sm text-chalk/50">
        <span class="flex items-center space-x-2.5">
          <Calendar class="h-5 w-5" />
          <span>{postedAt}</span>
        </span>
        <span class="flex items-center space-x-2.5">
          <Clock class="h-5 w-5" />
          <span>{frontmatter.readingTime} min read</span>
        </span>
      </div>
      <p class="pt-4 text-chalk/60">{frontmatter.excerpt}</p>
    </div>
  </section>
  <article class="container">
    <div class="prose mx-auto max-w-3xl py-8">
      <slot />
      <div class="mt-12">
        <a href="/blog" class="btn no-underline">
          &larr; Back to blog archive</a
        >
      </div>
    </div>
  </article>
</SiteLayout>
